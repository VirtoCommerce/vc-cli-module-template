{
  "$schema": "http://json.schemastore.org/template",
  "author": "VirtoWay",
  "classifications": [ "ecommerce", "platform", "virtocommerce", "virto", "commerce", "experience", "api", "xapi" ],
  "identity": "VirtoCommerce3.Module.DBA.XAPI",
  "name": "Virto Commerce 3.x Database Agnostic and XAPI Module Template",
  "shortName": "vc-module-dba-xapi",
  "guids": [
    "11111111-1111-1111-1111-111111111111",
    "22222222-2222-2222-2222-222222222222",
    "33333333-3333-3333-3333-333333333333",
    "44444444-4444-4444-4444-444444444444",
    "55555555-5555-5555-5555-555555555555",
    "66666666-6666-6666-6666-666666666666",
    "77777777-7777-7777-7777-777777777777",
    "88888888-8888-8888-8888-888888888888",
    "99999999-9999-9999-9999-999999999999",
    "AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA",
    "BBBBBBBB-BBBB-BBBB-BBBB-BBBBBBBBBBBB",
    "CCCCCCCC-CCCC-CCCC-CCCC-CCCCCCCCCCCC"
  ],
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "Author": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your name",
      "defaultValue": "Virto Commerce",
      "replaces": "{Author}"
    },
    "CompanyName": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your company name",
      "defaultValue": "Virto Commerce",
      "replaces": "{CompanyName}"
    },
    "ModuleName": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your module name",
      "defaultValue": "Foo Bar",
      "replaces": "{ModuleName}",
      "fileRename": "{ModuleName}"
    },
    "ModuleVersion": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your module version",
      "defaultValue": "3.1000.0",
      "replaces": "{ModuleVersion}"
    },
    "PlatformVersion": {
      "type": "parameter",
      "dataType": "string",
      "description": "Required Platform Version",
      "defaultValue": "3.1007.2",
      "replaces": "{PlatformVersion}"
    },
    "CoreVersion": {
      "type": "parameter",
      "dataType": "string",
      "description": "Required Core module Version",
      "defaultValue": "3.1001.2",
      "replaces": "{CoreVersion}"
    },
    "XapiVersion": {
      "type": "parameter",
      "dataType": "string",
      "description": "Required XAPI module Version",
      "defaultValue": "3.1003.0",
      "replaces": "{XapiVersion}"
    },
    "PascalCompanyName": {
      "type": "derived",
      "valueSource": "CompanyName",
      "valueTransform": "pascal"
    },
    "PascalModuleName": {
      "type": "derived",
      "valueSource": "ModuleName",
      "valueTransform": "pascal",
      "replaces": "{PascalModuleName}",
      "fileRename": "{PascalModuleName}"
    },
    "KebabModuleName": {
      "type": "derived",
      "valueSource": "ModuleName",
      "valueTransform": "kebab",
      "replaces": "{KebabModuleName}",
      "fileRename": "{KebabModuleName}"
    },
    "copyrightYear": {
      "type": "generated",
      "generator": "now",
      "parameters": {
        "format": "yyyy"
      },
      "replaces": "{Year}"
    },
    "joinedModuleTitle": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "CompanyName"
          },
          {
            "type": "ref",
            "value": "ModuleName"
          }
        ],
        "separator": " "
      },
      "replaces": "{ModuleTitle}"
    },
    "joinedNamespace": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "PascalCompanyName"
          },
          {
            "type": "ref",
            "value": "PascalModuleName"
          }
        ],
        "separator": "."
      },
      "fileRename": "{Namespace}",
      "replaces": "{Namespace}"
    }
  },
  "forms": {
    "kebab": {
      "identifier": "kebabCase"
    },
    "title": {
      "identifier": "titleCase"
    },
    "removeSpaces": {
      "identifier": "replace",
      "pattern": "\\s",
      "replacement": ""
    },
    "pascal": {
      "identifier": "chain",
      "steps": ["title", "removeSpaces"]
    }
  }
}
