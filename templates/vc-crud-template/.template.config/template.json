{
  "$schema": "http://json.schemastore.org/template",
  "author": "VirtoWay",
  "classifications": [ "ecommerce", "platform", "virtocommerce", "virto", "commerce", "crud" ],
  "identity": "VirtoCommerce3.CRUD",
  "name": "Virto Commerce 3.x CRUD Template",
  "shortName": "vc-crud",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "CompanyName": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your company name",
      "defaultValue": "Virto Commerce",
      "replaces": "{CompanyName}",
      "fileRename": "{CompanyName}"
    },
    "ModuleName": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your module name",
      "defaultValue": "Foo Bar",
      "replaces": "{ModuleName}",
      "fileRename": "{ModuleName}"
    },
    "EntityName": {
      "type": "parameter",
      "dataType": "string",
      "description": "Your model name",
      "defaultValue": "BazQux",
      "replaces": "{EntityName}",
      "fileRename": "{EntityName}"
    },
    "PascalCompanyName": {
      "type": "derived",
      "valueSource": "CompanyName",
      "valueTransform": "pascal"
    },
    "PascalModuleName": {
      "type": "derived",
      "valueSource": "ModuleName",
      "valueTransform": "pascal",
      "replaces": "{PascalModuleName}",
      "fileRename": "{PascalModuleName}"
    },
    "KebabModuleName": {
      "type": "derived",
      "valueSource": "ModuleName",
      "valueTransform": "kebab",
      "replaces": "{KebabModuleName}",
      "fileRename": "{KebabModuleName}"
    },
    "KebabEntityName": {
      "type": "derived",
      "valueSource": "EntityName",
      "valueTransform": "kebab",
      "replaces": "{KebabEntityName}",
      "fileRename": "{KebabEntityName}"
    },
    "joinedNamespace": {
      "type": "generated",
      "generator": "join",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "PascalCompanyName"
          },
          {
            "type": "ref",
            "value": "PascalModuleName"
          }
        ],
        "separator": "."
      },
      "fileRename": "{Namespace}",
      "replaces": "{Namespace}"
    }
  },
  "forms": {
    "kebab": {
      "identifier": "kebabCase"
    },
    "title": {
      "identifier": "titleCase"
    },
    "removeSpaces": {
      "identifier": "replace",
      "pattern": "\\s",
      "replacement": ""
    },
    "pascal": {
      "identifier": "chain",
      "steps": ["title", "removeSpaces"]
    }
  }
}
